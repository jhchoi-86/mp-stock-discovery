generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PENDING
  FREE_TRIAL
  FREE
  PAID
  ADMIN
  FREE_USER
  PRO_USER
}

enum Status {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  telegramId   String?   @map("telegram_id") @db.VarChar(255)
  role         Role      @default(FREE_USER)
  status       Status    @default(ACTIVE)
  referralCode String?   @unique @map("referral_code") @db.VarChar(10)
  referralCount Int      @default(0) @map("referral_count")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  refreshTokens RefreshToken[]
  usageLogs     UsageLog[]
  auditActions  AuditLog[]     @relation("AdminAction")
  auditTargets         AuditLog[]            @relation("TargetUser")
  reports              Report[]              @relation("ReportAuthor")
  subscriptionRequests SubscriptionRequest[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UsageLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  actionType String   @map("action_type") @db.VarChar(100)
  usageCount Int      @default(0) @map("usage_count")
  logDate    DateTime @map("log_date") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actionType, logDate])
  @@map("usage_logs")
}

model AuditLog {
  id           String   @id @default(uuid())
  adminId      String?  @map("admin_id")
  targetUserId String?  @map("target_user_id")
  action       String   @db.VarChar(255)
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  admin      User? @relation("AdminAction", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Report {
  id        String   @id @default(uuid())
  content   String   @db.Text
  authorId  String   @map("author_id")
  sentAt    DateTime @default(now()) @map("sent_at")

  author    User     @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sentAt(sort: Desc)])
  @@map("reports")
}

model Recommendation {
  id            String   @id @default(uuid())
  stockCode     String   @map("stock_code") @db.VarChar(50)
  stockName     String   @map("stock_name") @db.VarChar(100)
  entryPrice    Float    @map("entry_price")
  targetPrice   Float    @map("target_price")
  highestPrice  Float?   @map("highest_price")
  recommendedAt DateTime @default(now()) @map("recommended_at")

  @@index([recommendedAt(sort: Desc)])
  @@map("recommendations")
}

model SubscriptionRequest {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  status    SubscriptionStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_requests")
}

model SniperSignal {
  id         String   @id @default(uuid())
  signalId   String   @unique @map("signal_id") @db.VarChar(255)
  ticker     String   @db.VarChar(50)
  type       String   @db.VarChar(50)  // 'ENTRY', 'EXIT_WARN'
  entryPrice Float    @map("entry_price")
  time       String   @db.VarChar(50)
  grade      String?  @db.VarChar(10)
  score      Int?
  momentum   Json?    
  
  // Track continuous updates (e.g. tracking/exit warnings)
  isExited   Boolean  @default(false) @map("is_exited")
  exitPrice  Float?   @map("exit_price")
  exitReason String?  @map("exit_reason")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@map("sniper_signals")
}

model SignalCandidate {
  id           Int      @id @default(autoincrement())
  instrumentId Int
  timeframe    String
  condUp7      Boolean
  dhh2         Boolean
  triggerRsi   Boolean
  triggerVol   Boolean
  entryApproved Boolean
  isTrending   Boolean
  signalHH     Boolean
  displayScore Int
  entryPrice1  Float
  entryPrice2  Float?
  entryPrice3  Float?
  targetPrice  Float
  stopLoss     Float
  category     String
  sourceHash   String
  aiConfidenceScore Float?  @map("ai_confidence_score")
  aiAnalyzedAt      DateTime? @map("ai_analyzed_at")
  createdAt    DateTime @default(now())

  @@map("signal_candidates")
}

model Lead {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  source    String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model DailyStockSnapshot {
  id           Int      @id @default(autoincrement())
  code         String   @db.VarChar(20)
  name         String   @db.VarChar(100)
  category     String?  @db.VarChar(100)
  score        Int?
  adx          Int?
  trend        String?  @db.VarChar(20)
  currentPrice Float?   @map("current_price")
  entryPrice1  Float?   @map("entry_price1")
  entryPrice2  Float?   @map("entry_price2")
  entryPrice3  Float?   @map("entry_price3")
  targetPrice1 Float?   @map("target_price1")
  targetPrice2 Float?   @map("target_price2")
  stopLoss     Float?   @map("stop_loss")
  ema5         Float?   @map("ema5")
  ema10        Float?   @map("ema10")
  ema20        Float?   @map("ema20")
  ema60        Float?   @map("ema60")
  tradeAmount  BigInt?  @map("trade_amount")
  foreignBuy   String?  @map("foreign_buy")
  instBuy      String?  @map("inst_buy")
  yield        Float?
  styleTag     String?  @map("style_tag") @db.VarChar(100)
  aiComment    String?  @map("ai_comment") @db.Text
  dailyOpen    Float?   @map("daily_open")
  dailyHigh    Float?   @map("daily_high")
  dailyLow     Float?   @map("daily_low")
  isExecuted   Boolean? @default(false) @map("is_executed")
  executedAt   String?  @map("executed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([code])
  @@map("daily_stock_snapshots")
}

model DailySignalHistory {
  id        Int      @id @default(autoincrement())
  date      String   @db.VarChar(10) // "YYYY-MM-DD"
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(100)
  signals   String   @db.Text         // JSON stringified 30-min slots
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, code])
  @@map("daily_signal_history")
}

model SystemStat {
  id               String   @id @default(uuid())
  date             String   @unique @db.VarChar(10) // "YYYY-MM-DD"
  visitorCount     Int      @default(0) @map("visitor_count")
  loginCount       Int      @default(0) @map("login_count")
  signupCount      Int      @default(0) @map("signup_count")
  maxConcurrent    Int      @default(0) @map("max_concurrent")
  freeUserCount    Int      @default(0) @map("free_user_count")
  paidUserCount    Int      @default(0) @map("paid_user_count")
  cpuUsageAvg      Float?   @map("cpu_usage_avg")
  memUsageAvg      Float?   @map("mem_usage_avg")
  diskUsageAvg     Float?   @map("disk_usage_avg")
  healthStatus     String   @default("HEALTHY") @map("health_status")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("system_stats")
}

model IncidentLog {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  description String?   @db.Text
  severity    String    @default("INFO") // INFO, WARN, ERROR, FATAL
  status      String    @default("OPEN") // OPEN, RESOLVED, CLOSED
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  resolvedAt  DateTime? @map("resolved_at")
  handlerName String?   @map("handler_name") @db.VarChar(100)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("incident_logs")
}

model DailyTop5 {
  id           String   @id @default(uuid())
  date         String   // "YYYY-MM-DD"
  code         String   @db.VarChar(20)
  name         String   @db.VarChar(100)
  score        Int
  currentPrice Float    @map("current_price")
  yield        Float    // Change Rate (%)
  entryPrice1  Float    @map("entry_price1")
  entryPrice2  Float    @map("entry_price2")
  stopLoss     Float    @map("stop_loss")
  targetPrice1 Float    @map("target_price1")
  category     String   @db.VarChar(100)
  tradeAmount  BigInt   @map("trade_amount")
  foreignBuy   Int      @map("foreign_buy")    // Net buying (shares)
  instBuy      Int      @map("inst_buy")       // Net buying (shares)
  styleTag     String?  @map("style_tag") @db.VarChar(100)
  aiComment    String?  @map("ai_comment") @db.Text
  dailyOpen    Float?   @map("daily_open")
  dailyHigh    Float?   @map("daily_high")
  dailyLow     Float?   @map("daily_low")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([date, code])
  @@index([date])
  @@map("daily_top5_history")
}

model SyncSaveLog {
  id          String   @id @default(uuid())
  tagName     String   @map("tag_name") @db.VarChar(100) // e.g. "2026-04-08 14:30"
  snapshot    Json     @db.JsonB
  savedAt     DateTime @default(now()) @map("saved_at")

  @@index([savedAt(sort: Desc)])
  @@map("sync_save_logs")
}

model SignalsLog {
  id             Int       @id @default(autoincrement())
  stockCode      String    @map("stock_code") @db.VarChar(10)
  stockName      String?   @map("stock_name") @db.VarChar(50)
  signalType     String    @map("signal_type") @db.VarChar(20) // 'BUY_STRONG', 'BUY_WATCH', 'SELL'
  wbs1m          Decimal?  @map("wbs_1m") @db.Decimal(5, 2)
  wbs3m          Decimal?  @map("wbs_3m") @db.Decimal(5, 2)
  askBidRatio    Decimal?  @map("ask_bid_ratio") @db.Decimal(5, 2)
  pScore         Decimal?  @map("p_score") @db.Decimal(5, 2)
  predictiveRoi  Decimal?  @map("predictive_roi") @db.Decimal(5, 2)
  entryPrice     Int?      @map("entry_price")
  targetPrice    Int?      @map("target_price")
  stopPrice      Int?      @map("stop_price")
  occurredAt     DateTime  @default(now()) @map("occurred_at") @db.Timestamptz
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz
  actualMaxGain  Decimal?  @map("actual_max_gain") @db.Decimal(5, 2)
  isSuccess      Boolean?  @map("is_success")

  @@index([stockCode, occurredAt(sort: Desc)])
  @@map("signals_log")
}
