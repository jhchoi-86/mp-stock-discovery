generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FREE_USER
  PRO_USER
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  telegramId   String?   @map("telegram_id") @db.VarChar(255)
  role         Role      @default(FREE_USER)
  status       Status    @default(ACTIVE)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  refreshTokens RefreshToken[]
  usageLogs     UsageLog[]
  auditActions  AuditLog[]     @relation("AdminAction")
  auditTargets         AuditLog[]            @relation("TargetUser")
  reports              Report[]              @relation("ReportAuthor")
  subscriptionRequests SubscriptionRequest[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UsageLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  actionType String   @map("action_type") @db.VarChar(100)
  usageCount Int      @default(0) @map("usage_count")
  logDate    DateTime @map("log_date") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actionType, logDate])
  @@map("usage_logs")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  adminId      String   @map("admin_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  action       String   @db.VarChar(255)
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  admin      User  @relation("AdminAction", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text
  authorId  String   @map("author_id") @db.Uuid
  sentAt    DateTime @default(now()) @map("sent_at")

  author    User     @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([sentAt(sort: Desc)])
  @@map("reports")
}

model Recommendation {
  id            String   @id @default(uuid()) @db.Uuid
  stockCode     String   @map("stock_code") @db.VarChar(50)
  stockName     String   @map("stock_name") @db.VarChar(100)
  entryPrice    Float    @map("entry_price")
  targetPrice   Float    @map("target_price")
  highestPrice  Float?   @map("highest_price")
  recommendedAt DateTime @default(now()) @map("recommended_at")

  @@index([recommendedAt(sort: Desc)])
  @@map("recommendations")
}

model SubscriptionRequest {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  status    SubscriptionStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_requests")
}
