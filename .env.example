# [Security Remediation] Required Environment Variables Example
# 이 파일을 .env로 복사하거나 기존 .env 파일에 아래 내용을 추가하세요.

# --- [Phase 4] KIS API Authentication ---
KIS_APP_KEY=<YOUR_KIS_APP_KEY>
KIS_APP_SECRET=<YOUR_KIS_APP_SECRET>
NODE_SERVER_URL=http://127.0.0.1:3001

# --- [Phase 3] Telegram Bot Configuration ---
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<CHAT_ID_1,CHAT_ID_2>

# --- [Phase 2] Admin Whitelist (Comma separated) ---
# 하드코딩된 이메일을 대체할 관리자 명단입니다.
ADMIN_WHITELIST=admin@example.com

# --- [Phase 1] Deployment Configuration (Optional) ---
# 배포 스크립트(aws_update.bat)에서 사용할 환경 변수입니다.
# MP_SSH_KEY=C:\Users\danbe\Documents\mp-key.pem
# MP_SSH_USER=ubuntu
# MP_SSH_HOST=15.134.243.209

# --- [Phase 1] Frontend HMR Configuration (Optional) ---
# Vite 개발 서버용 외부 IP 설정입니다.
VITE_HMR_HOST=15.134.243.209

# --- [Existing] Database & JWT ---
DATABASE_URL="postgresql://user:password@127.0.0.1:5432/postgres?schema=public"
JWT_ACCESS_SECRET=<YOUR_JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<YOUR_JWT_REFRESH_SECRET>
CORE_INTEGRITY_HASH=<YOUR_CORE_INTEGRITY_HASH>
