# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---- NEW: PostgreSQL & Auth Configurations ----
# PostgreSQL Supabase Connection String format
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"

# JWT Secrets for Authentication
JWT_ACCESS_SECRET="your_jwt_access_secret_key_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_here"

# Frontend URL (For CORS & Cookie domains)
CLIENT_URL="http://localhost:5173"
# CLIENT_URL="http://13.211.128.167"

# ── 신규 인프라 ──
REDIS_URL="redis://127.0.0.1:6379"
# ── 보안 ──
ADMIN_WHITELIST_IPS="1.2.3.4,5.6.7.8"
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800
# ── S3 (Excel 리포트) ──
